{
  "functions": {
    "api/ikigai-bridge.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/leaderboard.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/reset-leaderboard.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/community.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/community-replies.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/mod-commands.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/friends.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/messages.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, DELETE, PATCH, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, X-IUA-Nexus-Key, Authorization, X-Admin-Key" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
