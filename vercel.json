{
  "crons": [
    {
      "path": "/api/mod-stats?action=snapshot",
      "schedule": "0 3 * * *"
    }
  ],
  "functions": {
    "api/ikigai-bridge.js": { "memory": 128, "maxDuration": 10 },
    "api/leaderboard.js":   { "memory": 128, "maxDuration": 10 },
    "api/reset-leaderboard.js": { "memory": 128, "maxDuration": 10 },
    "api/community.js":      { "memory": 128, "maxDuration": 10 },
    "api/community-replies.js": { "memory": 128, "maxDuration": 10 },
    "api/mod-commands.js":   { "memory": 128, "maxDuration": 10 },
    "api/mod-channel.js":    { "memory": 128, "maxDuration": 15 },
    "api/mod-events.js":     { "memory": 128, "maxDuration": 15 },
    "api/mod-users.js":      { "memory": 128, "maxDuration": 15 },
    "api/mod-moderation.js": { "memory": 128, "maxDuration": 15 },
    "api/mod-polls.js":      { "memory": 128, "maxDuration": 15 },
    "api/mod-stats.js":      { "memory": 128, "maxDuration": 15 },
    "api/mod-overlays.js":   { "memory": 128, "maxDuration": 10 },
    "api/mod-schedule.js":   { "memory": 128, "maxDuration": 15 },
    "api/friends.js":        { "memory": 128, "maxDuration": 10 },
    "api/messages.js":       { "memory": 256, "maxDuration": 15 },
    "api/chat.js":           { "memory": 128, "maxDuration": 10 },
    "api/profile.js":        { "memory": 128, "maxDuration": 10 },
    "api/emotes.js":         { "memory": 128, "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, DELETE, PATCH, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, X-IUA-Nexus-Key, Authorization, X-Admin-Key" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/(.*).png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(.*).svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
